rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────
    // Helpers
    // ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // CMS admin: Firebase Auth user with @pricepick-cms.internal domain
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email != null &&
             request.auth.token.email.matches('.*@pricepick-cms\\.internal');
    }

    // The requesting user owns this document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // App user writing their own data (uid matches the user_id field)
    function isMyData(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ──────────────────────────────────────────
    // A. Users / Auth / Device
    // ──────────────────────────────────────────
    match /users/{userId} {
      // read를 isSignedIn()까지 완화: 앱의 "카카오 연동 회원 시뮬 로그인"이 CMS에 세팅된
      // 다른 회원 프로필을 조회해서 보여줘야 하기 때문(실제 Kakao SDK 연동 없이 데모용으로 흉내만 냄).
      allow read: if isSignedIn();
      // App users can create/update their own doc; admin can do anything
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /auth_providers/{providerId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
      match /consents/{consentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
      match /devices/{deviceId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // ──────────────────────────────────────────
    // B. Master Data (admin write, anyone can read)
    // ──────────────────────────────────────────
    match /affiliate_malls/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ticket_grades/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /grade_exchange_rules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // 운영 설정 싱글턴 문서 (예: settings/roulette = 행운룰렛 6칸 구성). 앱은 읽기만, 편집은 CMS(admin) 전용.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────
    // C. Purchase Attribution
    // ──────────────────────────────────────────
    match /click_logs/{docId} {
      allow read: if isAdmin() || isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /postbacks/{docId} {
      // read/create를 isSignedIn()까지 완화: "카카오 연동 회원 시뮬 로그인"으로 들어온 세션은
      // Firebase Auth uid가 CMS 세팅 회원의 실제 문서 ID와 다르므로 uid 일치 검사를 통과할 수 없다.
      // 앱은 postback을 "구매 발생" 이벤트로 생성만 하고(recordPurchase) 이후 상태 변경은 하지 않으므로
      // update는 owner-uid 검증을 유지한다.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow delete: if isAdmin();
    }
    match /click_postback_matches/{docId} {
      allow read: if isAdmin() || isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Immutable ledger – append-only. 수정 불가(불변). 단, 데모 리셋을 위해 admin 삭제만 허용.
    // read를 isSignedIn()까지 완화: "활동내역" 화면이 시뮬 로그인 회원의 원장을 조회해야 함.
    // 앱은 이 컬렉션에 쓰지 않는다(등급 확정·차감 계산은 백엔드 몫) — create는 owner-uid 검증 유지.
    match /ticket_transactions/{docId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.user_id == request.auth.uid);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────
    // D. User Assets
    // ──────────────────────────────────────────
    // 앱은 이 컬렉션을 읽기만 한다(가지급 묶음 노출, persona 지원 위해 read만 완화) —
    // 등급 확정으로 인한 생성/전환은 백엔드 몫이라 create/update는 owner-uid 검증을 유지한다.
    match /user_tickets/{docId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.user_id == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow delete: if isAdmin();
    }
    match /user_points/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Immutable ledger – append-only. 수정 불가(불변). 단, 데모 리셋을 위해 admin 삭제만 허용.
    // read를 isSignedIn()까지 완화: /app(html 프로토타입)의 "카카오 연동 회원 시뮬 로그인"이
    // 포인트 내역(마이 > 포인트)을 조회해야 함 — 다른 컬렉션과 동일한 이유(uid 불일치, postbacks 주석 참고).
    // 앱은 이 컬렉션에 쓰지 않으므로(포인트 적립/차감 계산은 CMS·백엔드 몫) create는 owner-uid 검증 유지.
    match /point_transactions/{docId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.user_id == request.auth.uid);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────
    // E. Gifticards
    // ──────────────────────────────────────────
    match /gifticons/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /gifticon_stock/{docId} {
      // 재고 차감은 백엔드 몫 — 앱은 요청만 남기고 재고를 직접 건드리지 않으므로 admin 전용으로 유지.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /gifticon_exchanges/{docId} {
      // create를 isSignedIn()까지 완화: 시뮬 로그인 지원 + 앱은 "요청(requested)"만 남기고
      // 실제 차감·완료 처리는 백엔드가 담당 — 그래서 update는 admin(백엔드/CMS) 전용으로 유지한다.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────
    // F. Contests / Events
    // ──────────────────────────────────────────
    match /raffles/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /raffle_entries/{docId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /weekly_draws/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /invites/{docId} {
      // read를 isSignedIn()까지 완화: "친구초대" 화면이 본인이 초대한 친구 목록을 보여줘야 함
      // (원래 admin 전용이라 본인도 못 읽던 규칙 — 노출 화면 추가하며 최소한으로 열었다).
      // 초대 관계 생성 자체는 백엔드(초대받은 사람의 실제 가입 완료 시점)가 처리 — 앱은 쓰지 않는다.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /daily_visits/{docId} {
      // read/create를 isSignedIn()까지 완화: 시뮬 로그인 지원 + "출석체크" 화면의 최소 액션 기록.
      // points_earned 등 보상 계산은 앱이 채우지 않는다 — 백엔드가 방문 기록을 보고 처리해야 할 몫.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /banners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /events/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────
    // G. Operations / System
    // ──────────────────────────────────────────
    match /notices/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /notifications/{docId} {
      // read를 isSignedIn()까지 완화: 시뮬 로그인 지원(알림 화면). 생성은 백엔드/CMS 전용 유지.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /inquiries/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /withdrawals/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /admin_accounts/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    // 관리자 행위/접근 로그 — 생성만 허용, 수정·삭제 불가(불변 감사 로그)
    match /admin_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // 데모 시나리오 정의 (CMS 시나리오 관리 — 데모 전용, admin 전용)
    match /demo_scenarios/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
